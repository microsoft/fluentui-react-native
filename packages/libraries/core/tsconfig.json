{
  "extends": "@fluentui-react-native/config/tsconfig.json",
  "compilerOptions": {
    "jsx": "react",
    "outDir": "lib",
    "declaration": true,
    "sourceMap": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "strict": true,
    "rootDir": "src"
  },
  "include": [
    "src"
  ]
}