{
  "_meta": {
    "description": "Default-value source mapping for non-color flex React Native tokens (spacing, radius, stroke width, typography). Each token resolves to a FluentUI React Native / Fluent 2 (v9-compatible) global token.",
    "prefixes": {
      "global.": "Raw global token — tokens-global.json, dot-path into the global tree (theme.tokens.global.*). Theme-invariant."
    },
    "direction": "flexToken <- fluentToken  (key = flex RN token, value = prefixed Fluent global token reference)",
    "fluentSource": "@fluentui-react-native/design-tokens-windows@0.56.0/light/tokens-global.json",
    "matching": {
      "spacing / radius / stroke / fontSize": "nearest value in the corresponding Fluent scale (size / corner / stroke / font.size).",
      "lineHeight": "flex line-height is relative (%); resolved to the nearest Fluent absolute font.lineHeight using fontSize x percent.",
      "fontWeight": "role match (regular/medium/semibold/bold) — flex Segoe weights (420/550/600/625) differ in value from Fluent (400/500/600/700).",
      "fontFamily": "role match (base / monospace)."
    },
    "notes": [
      "null = no equivalent Fluent global token; fall back to the flex source value in semantic.css.",
      "letterSpacing* are null — Fluent global has no letter-spacing/tracking token.",
      "fontFamilyContentEditorial is null — Fluent global has no serif family token.",
      "Flex has finer/larger steps than Fluent in a few scales (e.g. radius 16/24/28, spacing 96); nearest emits the closest Fluent token — prefer the flex default where an exact step matters."
    ]
  },
