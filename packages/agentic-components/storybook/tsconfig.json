{
  "extends": "@fluentui-react-native/scripts/tsconfig",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [".rnstorybook", "StorybookApp.tsx", "index.js", "metro.config.js"],
  "exclude": [".rnstorybook/storybook.requires.ts"]
}
