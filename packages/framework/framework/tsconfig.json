    },
    {
      "path": "../../../scripts/tsconfig.json"
    },
    {
      "path": "../../theming/theme-types/tsconfig.json"
    },
    {
      "path": "../../utils/tokens/tsconfig.json"
    },
    {
      "path": "../use-slot/tsconfig.json"
    },
    {
      "path": "../use-slots/tsconfig.json"
